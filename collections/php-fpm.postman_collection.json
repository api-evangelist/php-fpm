          "request": {
            "name": "Get PHP-FPM pool status",
            "description": {
              "content": "Returns PHP-FPM pool metrics. The output format is selected via a\nquery-string flag and may include per-process detail when `full`\nis set. The default response is plain text.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "fpm-status"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "full",
                  "value": "<string>",
                  "description": "When present, includes per-process detail."
                },
                {
                  "disabled": false,
                  "key": "json",
                  "value": "<string>",
                  "description": "Return JSON output."
                },
                {
                  "disabled": false,
                  "key": "xml",
                  "value": "<string>",
                  "description": "Return XML output."
                },
                {
                  "disabled": false,
                  "key": "html",
                  "value": "<string>",
                  "description": "Return HTML output."
                },
                {
                  "disabled": false,
                  "key": "openmetrics",
                  "value": "<string>",
                  "description": "Return OpenMetrics output."
                }
              ],
              "variable": [
                {
                  "description": "Hostname of the web server proxying FastCGI requests.",
